# portal-kasa provisioning configuration. Read by both install.sh and install.ps1.

# The app to install and open.
PKG=com.portal.kasa
# Launcher activity opened after install (the app has a normal icon — we just open it).
LAUNCH_ACTIVITY=com.portal.kasa/.MainActivity

# Where the APK comes from:
#   APK_GLOB        - a local APK to install (first match wins). Drop a built APK in apks/
#                     to install it directly instead of downloading.
#   RELEASE_REPO    - GitHub repo whose LATEST release's .apk asset is downloaded when no
#                     local APK is present.
#   RELEASE_APK_URL - pin a specific .apk URL (overrides RELEASE_REPO).
APK_GLOB=apks/*.apk
RELEASE_REPO=rudysev/portal-kasa
RELEASE_APK_URL=
