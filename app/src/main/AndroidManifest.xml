<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Allow a MulticastLock so Wi-Fi delivers the plugs' broadcast discovery replies. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kasa">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Kasa">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Voice-control plugin: the assistant (Jarvis) discovers this exported provider via the
             ToolContract API and calls it to turn plugs on/off. Off until the user enables "Kasa Plugs" in
             the assistant's Settings → External tools. -->
        <provider
            android:name=".provider.KasaToolProvider"
            android:authorities="com.portal.kasa.tools"
            android:exported="true">
            <meta-data
                android:name="com.portal.assistant.tools"
                android:value="@string/portal_tools" />
            <!-- One-sentence summary for the assistant's Settings row (ToolContract META_SUMMARY). -->
            <meta-data
                android:name="com.portal.assistant.tools.summary"
                android:value="@string/portal_tools_summary" />
        </provider>
    </application>

</manifest>
